# Terraform
**/.terraform/*
*.tfstate
*.tfstate.*
*.tfplan
tfplan
crash.log
crash.*.log

# Never commit real secrets / per-environment inputs
terraform.tfvars
*.auto.tfvars
*.tfvars.json
!terraform.tfvars.example

# Lock file — COMMIT this in most cases. Keep the next line commented.
# .terraform.lock.hcl

# SSH keys, certs
*.pem
*.key
id_rsa*
id_ed25519*

# IDE / OS noise
.vscode/
.idea/
.DS_Store
*.swp

# Phase-scoping — .disabled files are local-only and not part of the committed code
terraform/*.tf.disabled

# Terraform backups (generated on apply, may contain real IPs/secrets)
terraform/backups/

# Generated CA certs (recreated by Terraform on each provision)
*.crt
terraform/nimbus-ca.crt

# One-off bootstrap scripts (functionality baked into module cloud-init templates)
install-obs.sh
install-monitoring.sh

# Cloudflare / Argo Tunnel credential files (binary token files, no extension)
*=
